__pycache__/
*.pyc
*.egg-info/
# The live config holds local settings and secrets (telegram token) and is
# never tracked; config.example.json is the shipped template.
config.json
config.yaml
lisan.sqlite
embeddings.bin
.DS_Store

# User-local vault data. Keep personal memories, reports, transcripts, and
# primer files out of the public repo even when LISAN_VAULT points at the
# repo-local fallback path.
lisan-vault/
Draft5.md
lisan-vault/drafts/
lisan-vault/reports/
lisan-vault/logs/
lisan-vault/transcripts/
lisan-vault/backup.md
lisan-vault/primer/current-brief.md
# Explicit belt-and-suspenders coverage for the vault-local high-stakes file.
lisan-vault/primer/high-stakes.yaml

# ── Sensitive-data firewall (2026-07-05, real data now flows) ──────────────
# No log file is ever publishable: logs carry chat blurbs, the instance's
# self-chosen name, and — with real data — the owner's life. Same for eval
# outputs, baselines, traces, and anything conversation-shaped.
*.log
*.jsonl
logs/
traces/
evals/baselines/
eval-reports/
*.sqlite
*.sqlite-journal
*.sqlite-wal

