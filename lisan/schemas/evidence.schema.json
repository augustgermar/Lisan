{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "evidence",
  "type": "object",
  "required": [
    "id", "type", "created", "created_at", "updated", "status", "significance",
    "domain_primary", "domain_secondary", "arena", "privacy", "summary", "links",
    "confidence", "confidence_basis", "last_confirmed", "review_after",
    "source_type", "actors", "sensitivity", "reliability", "observed_facts",
    "linked_claims", "linked_episodes"
  ],
  "properties": {
    "id": {"type": "string"},
    "type": {"type": "string", "enum": ["evidence"]},
    "created": {"type": "string"},
    "created_at": {"type": "string"},
    "updated": {"type": "string"},
    "status": {"type": "string"},
    "significance": {"type": "string"},
    "domain_primary": {"type": "string"},
    "domain_secondary": {"type": "array", "items": {"type": "string"}},
    "arena": {"type": "string"},
    "arena_primary": {"type": "string"},
    "arena_secondary": {"type": "array", "items": {"type": "string"}},
    "privacy": {"type": "string"},
    "disclosure": {
      "type": "string",
      "enum": ["private", "personal", "public"],
      "description": "Default sharing posture (private/personal/public). A prior for the future external disclosure gate, not a hard rule. Has no effect on internal retrieval."
    },
    "compartments": {"type": "array", "items": {"type": "string"}, "deprecated": true},
    "allowed_contexts": {"type": "array", "items": {"type": "string"}, "deprecated": true},
    "blocked_contexts": {"type": "array", "items": {"type": "string"}, "deprecated": true},
    "summary": {"type": "string"},
    "links": {"type": "array", "items": {"type": "string"}},
    "confidence": {"type": "string"},
    "confidence_basis": {"type": "string"},
    "last_confirmed": {"type": "string"},
    "review_after": {"type": "string"},
    "source_type": {"type": "string"},
    "source_uri": {"type": ["string", "null"]},
    "artifact_ref": {"type": ["string", "null"]},
    "artifact_hash": {"type": ["string", "null"]},
    "timestamp_of_artifact": {"type": ["string", "null"]},
    "batch_id": {"type": ["string", "null"]},
    "actors": {"type": "array", "items": {"type": "string"}},
    "sensitivity": {"type": "string", "enum": ["low", "medium", "high", "restricted", "sealed"]},
    "reliability": {"type": "string", "enum": ["low", "medium", "high"]},
    "observed_facts": {"type": "array", "items": {"type": "string"}},
    "verbatim_excerpt": {"type": "string"},
    "linked_claims": {"type": "array", "items": {"type": "string"}},
    "linked_episodes": {"type": "array", "items": {"type": "string"}}
  }
}
