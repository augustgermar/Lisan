{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "artifact",
  "type": "object",
  "required": [
    "id", "type", "created", "created_at", "updated", "status", "significance",
    "domain_primary", "domain_secondary", "arena", "privacy", "compartments",
    "allowed_contexts", "blocked_contexts", "summary", "links",
    "confidence", "confidence_basis", "last_confirmed", "review_after",
    "source_type", "source_path", "artifact_hash", "file_name", "file_ext",
    "size_bytes", "modified_at", "imported_at", "ingestion_status",
    "sensitivity", "linked_evidence", "linked_claims"
  ],
  "properties": {
    "id": {"type": "string"},
    "type": {"type": "string", "enum": ["artifact"]},
    "created": {"type": "string"},
    "created_at": {"type": "string"},
    "updated": {"type": "string"},
    "status": {
      "type": "string",
      "enum": ["discovered", "parsed", "evidence_extracted", "failed", "skipped", "quarantined", "active"]
    },
    "significance": {"type": "string"},
    "domain_primary": {"type": "string"},
    "domain_secondary": {"type": "array", "items": {"type": "string"}},
    "arena": {"type": "string"},
    "arena_primary": {"type": "string"},
    "arena_secondary": {"type": "array", "items": {"type": "string"}},
    "privacy": {"type": "string"},
    "compartments": {"type": "array", "items": {"type": "string"}},
    "allowed_contexts": {"type": "array", "items": {"type": "string"}},
    "blocked_contexts": {"type": "array", "items": {"type": "string"}},
    "summary": {"type": "string"},
    "links": {"type": "array", "items": {"type": "string"}},
    "confidence": {"type": "string"},
    "confidence_basis": {"type": "string"},
    "last_confirmed": {"type": "string"},
    "review_after": {"type": "string"},
    "source_type": {
      "type": "string",
      "enum": ["file", "markdown", "text", "pdf", "image", "email_export", "sms_export", "other"]
    },
    "source_path": {"type": "string"},
    "source_uri": {"type": ["string", "null"]},
    "batch_id": {"type": ["string", "null"]},
    "artifact_hash": {"type": "string"},
    "file_name": {"type": "string"},
    "file_ext": {"type": "string"},
    "mime_type": {"type": ["string", "null"]},
    "size_bytes": {"type": "integer"},
    "modified_at": {"type": "string"},
    "imported_at": {"type": "string"},
    "ingestion_status": {
      "type": "string",
      "enum": ["discovered", "parsed", "evidence_extracted", "failed", "skipped", "quarantined"]
    },
    "sensitivity": {"type": "string", "enum": ["low", "medium", "high", "restricted", "sealed"]},
    "extracted_text_ref": {"type": ["string", "null"]},
    "linked_evidence": {"type": "array", "items": {"type": "string"}},
    "linked_claims": {"type": "array", "items": {"type": "string"}},
    "parse_errors": {"type": "array", "items": {"type": "string"}}
  }
}
