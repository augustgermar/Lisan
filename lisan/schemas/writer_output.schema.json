{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "writer_output",
  "type": "object",
  "required": [
    "record_type",
    "summary",
    "significance",
    "frontmatter",
    "sections",
    "questions",
    "significance_rationale"
  ],
  "properties": {
    "record_type": { "type": "string" },
    "summary": { "type": "string" },
    "significance": { "type": "string", "enum": ["low", "medium", "high"] },
    "frontmatter": { "type": "object" },
    "sections": { "type": "object" },
    "questions": { "type": "array", "items": { "type": "string" } },
    "significance_rationale": { "type": "string" },
    "entities_to_create": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "subtype", "summary"],
        "properties": {
          "name":    { "type": "string" },
          "subtype": { "type": "string", "enum": ["person", "place", "thing", "project", "organization"] },
          "summary": { "type": "string" }
        }
      }
    },
    "state_updates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["arena", "summary"],
        "properties": {
          "arena":      { "type": "string" },
          "summary":    { "type": "string" },
          "confidence": { "type": "string", "enum": ["low", "medium", "high"] }
        }
      }
    },
    "open_loops_to_create": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "next_action", "summary"],
        "properties": {
          "title":       { "type": "string" },
          "next_action": { "type": "string" },
          "summary":     { "type": "string" },
          "priority":    { "type": "string", "enum": ["low", "medium", "high"] },
          "arena":       { "type": "string" }
        }
      }
    },
    "decisions_to_create": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "summary"],
        "properties": {
          "title":                  { "type": "string" },
          "summary":                { "type": "string" },
          "arena":                  { "type": "string" },
          "significance":           { "type": "string", "enum": ["low", "medium", "high"] },
          "alternatives_considered":{ "type": "array", "items": { "type": "string" } },
          "revisit_conditions":     { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
