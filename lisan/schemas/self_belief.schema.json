{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "self_belief",
  "type": "object",
  "required": [
    "id", "type", "created", "updated", "status", "significance",
    "domain_primary", "domain_secondary", "privacy", "summary", "links",
    "confidence", "confidence_basis", "last_confirmed", "review_after",
    "belief_confidence", "evidence_refs", "revisions"
  ],
  "properties": {
    "id": {"type": "string"},
    "type": {"type": "string", "enum": ["self_belief"]},
    "created": {"type": "string"},
    "updated": {"type": "string"},
    "status": {"type": "string"},
    "significance": {"type": "string"},
    "domain_primary": {"type": "string"},
    "domain_secondary": {"type": "array", "items": {"type": "string"}},
    "arena_primary": {"type": "string"},
    "arena_secondary": {"type": "array", "items": {"type": "string"}},
    "privacy": {"type": "string"},
    "disclosure": {"type": "string", "enum": ["private", "personal", "public"]},
    "summary": {"type": "string"},
    "links": {"type": "array", "items": {"type": "string"}},
    "confidence": {"type": "string"},
    "confidence_basis": {"type": "string"},
    "last_confirmed": {"type": "string"},
    "review_after": {"type": "string"},
    "belief_confidence": {"type": "string", "enum": ["low", "medium", "high"]},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "revisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "previous_statement", "reason", "evidence_refs"],
        "properties": {
          "date": {"type": "string"},
          "previous_statement": {"type": "string"},
          "previous_confidence": {"type": "string"},
          "reason": {"type": "string"},
          "evidence_refs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
        }
      }
    }
  }
}
