{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "skeptical_review",
  "type": "object",
  "required": [
    "id", "type", "created", "created_at", "updated", "status", "significance",
    "domain_primary", "domain_secondary", "arena", "privacy", "summary", "links",
    "confidence", "confidence_basis", "last_confirmed", "review_after",
    "reviewed_record_id", "reviewed_record_type", "approved", "risk",
    "recommended_action", "issues", "priority_questions",
    "alternative_hypotheses", "evidence_needed", "claim_updates",
    "confidence_adjustments", "reasoning_errors"
  ],
  "properties": {
    "id": {"type": "string"},
    "type": {"type": "string", "enum": ["skeptical_review"]},
    "created": {"type": "string"},
    "created_at": {"type": "string"},
    "updated": {"type": "string"},
    "status": {"type": "string"},
    "significance": {"type": "string"},
    "domain_primary": {"type": "string"},
    "domain_secondary": {"type": "array", "items": {"type": "string"}},
    "arena": {"type": "string"},
    "arena_primary": {"type": "string"},
    "arena_secondary": {"type": "array", "items": {"type": "string"}},
    "privacy": {"type": "string"},
    "disclosure": {
      "type": "string",
      "enum": ["private", "personal", "public"],
      "description": "Default sharing posture (private/personal/public). A prior for the future external disclosure gate, not a hard rule. Has no effect on internal retrieval."
    },
    "compartments": {"type": "array", "items": {"type": "string"}, "deprecated": true},
    "allowed_contexts": {"type": "array", "items": {"type": "string"}, "deprecated": true},
    "blocked_contexts": {"type": "array", "items": {"type": "string"}, "deprecated": true},
    "summary": {"type": "string"},
    "links": {"type": "array", "items": {"type": "string"}},
    "confidence": {"type": "string"},
    "confidence_basis": {"type": "string"},
    "last_confirmed": {"type": "string"},
    "review_after": {"type": "string"},
    "reviewed_record_id": {"type": "string"},
    "reviewed_record_type": {"type": "string"},
    "approved": {"type": "boolean"},
    "risk": {"type": "string", "enum": ["low", "medium", "high"]},
    "recommended_action": {"type": "string", "enum": ["approve", "revise", "hold"]},
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "message"],
        "properties": {
          "type": {"type": "string"},
          "message": {"type": "string"}
        }
      }
    },
    "priority_questions": {"type": "array", "items": {"type": "string"}},
    "alternative_hypotheses": {"type": "array", "items": {"type": "string"}},
    "evidence_needed": {"type": "array", "items": {"type": "string"}},
    "claim_updates": {"type": "array", "items": {"type": "object"}},
    "confidence_adjustments": {"type": "array", "items": {"type": "object"}},
    "reasoning_errors": {"type": "array", "items": {"type": "string"}}
  }
}
