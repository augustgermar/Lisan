{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "dreamer_output",
  "type": "object",
  "required": ["task", "summary", "findings", "recommendations"],
  "properties": {
    "task": { "type": "string" },
    "summary": { "type": "string" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "message"],
        "properties": {
          "type": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "approved": { "type": "boolean" },
    "notes": { "type": "string" }
  }
}
