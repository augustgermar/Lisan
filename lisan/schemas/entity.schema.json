{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "entity",
  "type": "object",
  "required": [
    "id", "type", "created", "updated", "status", "significance",
    "arena_primary", "arena_secondary", "privacy", "compartments",
    "allowed_contexts", "blocked_contexts", "summary", "links",
    "confidence", "confidence_basis", "last_confirmed", "review_after",
    "subtype", "canonical_name", "aliases", "disambiguation",
    "epoch", "epoch_started", "previous_epochs"
  ],
  "properties": {
    "id": {"type": "string"},
    "type": {"type": "string", "enum": ["entity"]},
    "created": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "updated": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "status": {"type": "string"},
    "significance": {"type": "string"},
    "arena_primary": {"type": "string"},
    "arena_secondary": {"type": "array", "items": {"type": "string"}},
    "privacy": {"type": "string"},
    "compartments": {"type": "array", "items": {"type": "string"}},
    "allowed_contexts": {"type": "array", "items": {"type": "string"}},
    "blocked_contexts": {"type": "array", "items": {"type": "string"}},
    "summary": {"type": "string"},
    "links": {"type": "array", "items": {"type": "string"}},
    "confidence": {"type": "string"},
    "confidence_basis": {"type": "string"},
    "last_confirmed": {"type": "string"},
    "review_after": {"type": "string"},
    "subtype": {"type": "string"},
    "canonical_name": {"type": "string"},
    "aliases": {"type": "array", "items": {"type": "string"}},
    "disambiguation": {"type": "string"},
    "epoch": {"type": "integer"},
    "epoch_started": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "previous_epochs": {"type": "array"}
  }
}

