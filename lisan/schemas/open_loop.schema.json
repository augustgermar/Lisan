{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "open_loop",
  "type": "object",
  "required": [
    "id", "type", "created", "updated", "status", "significance",
    "domain_primary", "domain_secondary", "privacy", "summary", "links",
    "confidence", "confidence_basis", "last_confirmed", "review_after",
    "priority", "owner", "next_action", "blocked_by"
  ],
  "properties": {
    "id": {"type": "string"},
    "type": {"type": "string", "enum": ["open_loop"]},
    "created": {"type": "string"},
    "updated": {"type": "string"},
    "status": {"type": "string"},
    "significance": {"type": "string"},
    "domain_primary": {"type": "string"},
    "domain_secondary": {"type": "array", "items": {"type": "string"}},
    "arena_primary": {"type": "string"},
    "arena_secondary": {"type": "array", "items": {"type": "string"}},
    "privacy": {"type": "string"},
    "disclosure": {
      "type": "string",
      "enum": ["private", "personal", "public"],
      "description": "Default sharing posture (private/personal/public). A prior for the future external disclosure gate, not a hard rule. Has no effect on internal retrieval."
    },
    "compartments": {"type": "array", "items": {"type": "string"}, "deprecated": true},
    "allowed_contexts": {"type": "array", "items": {"type": "string"}, "deprecated": true},
    "blocked_contexts": {"type": "array", "items": {"type": "string"}, "deprecated": true},
    "summary": {"type": "string"},
    "links": {"type": "array", "items": {"type": "string"}},
    "confidence": {"type": "string"},
    "confidence_basis": {"type": "string"},
    "last_confirmed": {"type": "string"},
    "review_after": {"type": "string"},
    "priority": {"type": "string"},
    "owner": {"type": "string"},
    "next_action": {"type": "string"},
    "blocked_by": {},
    "resolved_by": {"type": "string"},
    "resolved_note": {"type": "string"},
    "resolved_at": {"type": "string"},
    "execute_asap": {"type": "boolean", "description": "WO-ADJUTANT: poller selects this loop regardless of due date. Optional, never required."},
    "due": {"type": "string", "description": "WO-ADJUTANT: ISO date; a tasked loop becomes pollable when due is now-or-past. Distinct from review_after, which is a review cadence, not an execution trigger."},
    "task_kind": {"type": "string", "enum": ["run_script", "research", "collect", "draft", "notify"]},
    "task_payload": {"type": "object", "description": "Executor arguments, verbatim from capture — never from generation."},
    "task_status": {"type": "string", "enum": ["pending", "running", "blocked", "expired", "resolved"]}
  }
}
